<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">

    <Style x:Key="OdsInfoBarStyle" TargetType="controls:InfoBar">
        <Setter Property="Background" Value="{StaticResource OdsPanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource OdsBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource OdsPanelCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource OdsPanelPadding}" />
    </Style>

    <Style x:Key="OdsSuccessInfoBarStyle" TargetType="controls:InfoBar" BasedOn="{StaticResource OdsInfoBarStyle}">
        <Setter Property="BorderBrush" Value="{StaticResource OdsSuccessBrush}" />
    </Style>

    <Style x:Key="OdsWarningInfoBarStyle" TargetType="controls:InfoBar" BasedOn="{StaticResource OdsInfoBarStyle}">
        <Setter Property="BorderBrush" Value="{StaticResource OdsWarningBrush}" />
    </Style>

    <Style x:Key="OdsErrorInfoBarStyle" TargetType="controls:InfoBar" BasedOn="{StaticResource OdsInfoBarStyle}">
        <Setter Property="BorderBrush" Value="{StaticResource OdsErrorBrush}" />
    </Style>
</ResourceDictionary>
