<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <FontFamily x:Key="OdsFontFamilyBase">Segoe UI, Helvetica Neue, Helvetica, Arial</FontFamily>

    <x:Double x:Key="OdsFontSizeDisplay1">60</x:Double>
    <x:Double x:Key="OdsFontSizeDisplay2">50</x:Double>
    <x:Double x:Key="OdsFontSizeDisplay3">40</x:Double>
    <x:Double x:Key="OdsFontSizeDisplay4">34</x:Double>

    <x:Double x:Key="OdsFontSizeHeading1">34</x:Double>
    <x:Double x:Key="OdsFontSizeHeading2">30</x:Double>
    <x:Double x:Key="OdsFontSizeHeading3">24</x:Double>
    <x:Double x:Key="OdsFontSizeHeading4">20</x:Double>
    <x:Double x:Key="OdsFontSizeHeading5">18</x:Double>
    <x:Double x:Key="OdsFontSizeHeading6">16</x:Double>

    <x:Double x:Key="OdsFontSizeLead">20</x:Double>
    <x:Double x:Key="OdsFontSizeBody">16</x:Double>
    <x:Double x:Key="OdsFontSizeSmall">14</x:Double>

    <x:Double x:Key="OdsLineHeightDisplay1">60</x:Double>
    <x:Double x:Key="OdsLineHeightDisplay2">50</x:Double>
    <x:Double x:Key="OdsLineHeightDisplay3">40</x:Double>
    <x:Double x:Key="OdsLineHeightDisplay4">34</x:Double>
    <x:Double x:Key="OdsLineHeightHeading1">34</x:Double>
    <x:Double x:Key="OdsLineHeightHeading2">32</x:Double>
    <x:Double x:Key="OdsLineHeightHeading3">26</x:Double>
    <x:Double x:Key="OdsLineHeightHeading4">22</x:Double>
    <x:Double x:Key="OdsLineHeightHeading5">20</x:Double>
    <x:Double x:Key="OdsLineHeightHeading6">18</x:Double>
    <x:Double x:Key="OdsLineHeightLead">30</x:Double>
    <x:Double x:Key="OdsLineHeightBody">24</x:Double>
    <x:Double x:Key="OdsLineHeightSmall">16</x:Double>

    <Style x:Key="OdsPageTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OdsFontFamilyBase}" />
        <Setter Property="FontSize" Value="{StaticResource OdsFontSizeHeading1}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="LineHeight" Value="{StaticResource OdsLineHeightHeading1}" />
        <Setter Property="Foreground" Value="{StaticResource OdsTextPrimaryBrush}" />
    </Style>

    <Style x:Key="OdsSectionTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OdsFontFamilyBase}" />
        <Setter Property="FontSize" Value="{StaticResource OdsFontSizeHeading5}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="LineHeight" Value="{StaticResource OdsLineHeightHeading5}" />
        <Setter Property="Foreground" Value="{StaticResource OdsTextPrimaryBrush}" />
    </Style>

    <Style x:Key="OdsBodyTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OdsFontFamilyBase}" />
        <Setter Property="FontSize" Value="{StaticResource OdsFontSizeBody}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="{StaticResource OdsLineHeightBody}" />
        <Setter Property="Foreground" Value="{StaticResource OdsTextPrimaryBrush}" />
    </Style>

    <Style x:Key="OdsSmallTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OdsFontFamilyBase}" />
        <Setter Property="FontSize" Value="{StaticResource OdsFontSizeSmall}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="{StaticResource OdsLineHeightSmall}" />
        <Setter Property="Foreground" Value="{StaticResource OdsTextPrimaryBrush}" />
    </Style>

    <Style x:Key="OdsMutedTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OdsFontFamilyBase}" />
        <Setter Property="FontSize" Value="{StaticResource OdsFontSizeBody}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="{StaticResource OdsLineHeightBody}" />
        <Setter Property="Foreground" Value="{StaticResource OdsTextSecondaryBrush}" />
    </Style>
</ResourceDictionary>
