<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="OdsPanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource OdsPanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource OdsBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource OdsPanelCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource OdsPanelPadding}" />
    </Style>

    <Style x:Key="OdsSurfacePanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource OdsSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource OdsBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource OdsPanelCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource OdsPanelPadding}" />
    </Style>

    <Style x:Key="OdsStatusPanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource OdsPanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource OdsAccentBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,3" />
        <Setter Property="CornerRadius" Value="{StaticResource OdsPanelCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource OdsPanelPadding}" />
    </Style>
</ResourceDictionary>
