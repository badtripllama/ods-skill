<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="OdsPrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource OdsAccentBrush}" />
        <Setter Property="Foreground" Value="{StaticResource OdsBlackBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource OdsAccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource OdsControlCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource OdsControlPadding}" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="OdsSecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource OdsWhiteBrush}" />
        <Setter Property="Foreground" Value="{StaticResource OdsTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource OdsBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource OdsControlCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource OdsControlPadding}" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="OdsDestructiveButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource OdsErrorBrush}" />
        <Setter Property="Foreground" Value="{StaticResource OdsWhiteBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource OdsErrorBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource OdsControlCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource OdsControlPadding}" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="OdsIconButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource OdsWhiteBrush}" />
        <Setter Property="Foreground" Value="{StaticResource OdsTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource OdsBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource OdsControlCornerRadius}" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="MinWidth" Value="36" />
        <Setter Property="MinHeight" Value="36" />
    </Style>
</ResourceDictionary>
